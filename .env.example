# =====================================================================
# portfolio/.env.example - PORTFOLIO project template. Copy to portfolio/.env.
# Project-specific deploy creds only. Isolated from other projects (trading-bot etc).
# Loaded on top of the workspace .env via: source scripts/loadenv.sh portfolio
# .env is gitignored + chmod 600. Never put real secrets in this .example file.
# =====================================================================

# --- AWS (deploy target for this site) ---
AWS_REGION=us-east-2                  # Ohio; matches the console
AWS_ACCESS_KEY_ID=                    # AWS access key id
AWS_SECRET_ACCESS_KEY=                # AWS secret access key

# --- GitHub (this project's repo) ---
GITHUB_TOKEN=                         # personal access token, if CI needs it
GITHUB_REPO=sbrick26/auto-portfolio
